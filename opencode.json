{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "qplaywright": {
      "type": "local",
      "enabled": true,
      "command": [
        "./.venv/Scripts/python.exe",
        "-m",
        "qplaywright.mcp_server"
      ],
      "environment": {
        "PYTHONPATH": "./"
      },
      "timeout": 15000
    }
  }
}